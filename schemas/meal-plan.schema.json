{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/meal-plan.schema.json",
  "title": "MealPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "days"
  ],
  "properties": {
    "days": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "day",
          "breakfast",
          "snack_1",
          "lunch",
          "snack_2",
          "dinner"
        ],
        "properties": {
          "day": {
            "type": "string",
            "enum": [
              "monday",
              "tuesday",
              "wednesday",
              "thursday",
              "friday",
              "saturday",
              "sunday"
            ]
          },
          "breakfast": {
            "$ref": "#/$defs/mealRef"
          },
          "snack_1": {
            "$ref": "#/$defs/mealRef"
          },
          "lunch": {
            "$ref": "#/$defs/mealRef"
          },
          "snack_2": {
            "$ref": "#/$defs/mealRef"
          },
          "dinner": {
            "$ref": "#/$defs/mealRef"
          }
        }
      }
    }
  },
  "$defs": {
    "mealRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recipe_id",
        "servings"
      ],
      "properties": {
        "recipe_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
        },
        "servings": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
